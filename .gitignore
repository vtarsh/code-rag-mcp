# Python cache
.pytest_cache/

# Claude Code agent worktrees (ephemeral, per-session)
.claude/worktrees/

# Org-specific profiles — local-only, never published.
# Only the generic example/ profile is tracked; real profiles (e.g. pay-com)
# contain internal/sensitive org data and stay out of this public repo.
profiles/*/
!profiles/example/

# Legacy root config and docs (migrated to profile)
/config.json
/docs/

# LaunchD plists (user-specific hardcoded paths)
*.plist

# Active profile marker
.active_profile

